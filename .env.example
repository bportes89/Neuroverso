# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── Database (PostgreSQL 14+) ───────────────────────────────────────────────
DATABASE_URL=postgresql://neuroverso:neuroverso@localhost:5432/neuroverso
POSTGRES_USER=neuroverso
POSTGRES_PASSWORD=neuroverso
POSTGRES_DB=neuroverso

# ─── Cache / Queue (Redis 7+) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (JWT RS256 or HS256) ───────────────────────────────────────────────
# For production use RS256 with private/public key pair
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS S3 (sa-east-1) ──────────────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=neuroverso-storage

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── GOV.BR Integration ──────────────────────────────────────────────────────
GOVBR_CLIENT_ID=your-govbr-client-id
GOVBR_CLIENT_SECRET=your-govbr-client-secret
GOVBR_REDIRECT_URI=http://localhost:8080/v1/signatures/callback
GOVBR_AUTH_URL=https://sso.staging.acesso.gov.br
